# RentCast API key -- https://rentcast.io (rental listings). Required.
RENTCAST_API_KEY=
# Google Routes API key -- enable "Routes API" in Google Cloud (walk/drive/transit
# travel times). Required.
GOOGLE_ROUTES_API_KEY=
# CORS origin for the frontend dev server.
ALLOWED_ORIGIN=http://localhost:5173
# Self-tracked free-tier guardrails (decremented locally on each /search).
RENTCAST_STARTING_QUOTA=46
ROUTING_STARTING_QUOTA=40000
# Descriptive User-Agent for keyless Nominatim geocoding (their policy requires one).
GEOCODE_USER_AGENT=rent-finder-app/1.0 (https://github.com/vihan246/rent-finder)
